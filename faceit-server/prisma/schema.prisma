// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  email String @unique
  password String?

  nickname String @unique
  profilePic String?
  profilePictureId String?

  elo Int @default(1000)

  matchParticipants MatchParticipant[]
  eloHistory EloHistory[]
  playerStats PlayerStats?

  role UserRole @default(REGULAR)

  isVerified Boolean @default(false) @map("isverified")
  isTwoFactorEnabled Boolean @default(false) @map("is_two_factor_enabled")

  method AuthMethod

  accounts Account[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([elo])
  @@map("users")
}

model Account {
  id String @id @default(uuid())

  type String
  provider String

  providerAccountId String @map("provider_account_id")

  refreshToken String? @map("refresh_token")
  accessToken String? @map("access_token")
  expiresAt Int? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])
  userId String @map("user_id")

  @@unique([provider, providerAccountId])

  @@map("accounts")
}

model Token {
  id String @id @default(uuid())

  email String
  token String @unique
  type TokenType
  expiresIn DateTime @map("expires_in")

  @@map("tokens")
}

model Match {
  id String @id @default(uuid())

  matchType MatchType
  maxPlayersPerTeam Int

  status MatchStatus

  winnerTeam Int?

  team1Score Int @default(0)
  team2Score Int @default(0)

  cancelledBy String?
  cancellationReason String?

  eloHistory EloHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  finishedAt DateTime?

  participants MatchParticipant[]

  @@index([status])
  @@index([createdAt])
  @@map("matches")
}

model MatchParticipant {
  id String @id @default(uuid())

  match Match @relation(fields: [matchId], references: [id])
  matchId String

  user User @relation(fields: [userId], references: [id])
  userId String

  team Int

  isWinner Boolean

  eloBefore Int
  eloAfter Int

  kills Int @default(0)
  deaths Int @default(0)
  assists Int @default(0)

  headshots Int @default(0)
  mvpRounds Int @default(0)

  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@map("match_participants")
}

model EloHistory {
  id String @id @default(uuid())

  user User @relation(fields: [userId], references: [id])
  userId String

  match Match @relation(fields: [matchId], references: [id])
  matchId String

  eloChange Int

  eloBefore Int
  eloAfter Int

  calculationMethod String @default("fixed_25")

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("elo_history")
}

model PlayerStats {
  id String @id @default(uuid())

  user User @relation(fields: [userId], references: [id])
  userId String @unique

  totalMatches Int @default(0)
  totalWins Int @default(0)
  totalLosses Int @default(0)

  totalKills Int @default(0)
  totalDeaths Int @default(0)
  totalAssists Int @default(0)
  totalHeadshots Int @default(0)
  totalMvpRounds Int @default(0)

  updatedAt DateTime @updatedAt

  @@map("player_stats")
}

enum UserRole {
  REGULAR
  ADMIN
}

enum AuthMethod {
  CREADENTIALS
  GOOGLE
  DISCORD
}

enum TokenType {
  VERIFICATION
  TWO_FACTOR
  PASSWORD_RESET
}

enum MatchStatus {
  SEARCHING
  READY
  LIVE
  FINISHED
  CANCELLED
}

enum MatchType {
  ONE_VS_ONE
  TEAM
}